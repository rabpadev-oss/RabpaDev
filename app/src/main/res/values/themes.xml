<resources>

    <style name="Theme.RabpaDev" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_variant</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="ThemeOverlay.RabpaDev.AppBar" parent="ThemeOverlay.Material3.Dark">
        <item name="android:background">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
    </style>

    <style name="ThemeOverlay.RabpaDev.Popup" parent="ThemeOverlay.Material3.Dark">
        <item name="android:background">@color/surface_variant</item>
    </style>

</resources>
